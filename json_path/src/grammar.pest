literal = @{('a' .. 'z' | 'A' .. 'Z' | '0' .. '9' | "-" | "_" | "`" | "~" | "+" | "#" | "%" | "$" | "^" | "/" | ":")+}

string = _{("'" ~ (string_value) ~ "'") | ("\"" ~ (string_value) ~ "\"") | ("\"" ~ (string_value_escape_1) ~ "\"") | ("'" ~ (string_value_escape_2) ~ "'")}
    string_escape = @{"\\"}
    string_value = @{((!("\""|"\\"|"'") ~ ANY)+)*}
    string_value_escape_1 = @{((!("\""|"\\") ~ ANY)+ | string_escape ~ ("\"" | "\\"))*}
    string_value_escape_2 = @{((!("'"|"\\") ~ ANY)+ | string_escape ~ ("'" | "\\"))*}

string_list = {string ~ ("," ~ string)*}

pos_number = @{ASCII_NONZERO_DIGIT ~ ASCII_DIGIT*}
number = @{"-"? ~ ASCII_NONZERO_DIGIT ~ ASCII_DIGIT* | "-"? ~ ASCII_DIGIT}

decimal = @{number ~ ("." ~ ASCII_DIGIT+)?}

numbers_list = {number ~ ("," ~ number)*}

numbers_range = {(full_range | right_range | all_range | left_range)}
    right_range = {":" ~ number ~ ((":" ~ pos_number) | ":")?}
    all_range = {":" ~ ((":" ~ pos_number) | ":")?}
    left_range = {number ~ ":"  ~ ((":" ~ pos_number) | ":")?}
    full_range = {number ~ ":" ~ number  ~ ((":" ~ pos_number) | ":")?}

from_current = {"@" ~ root?}
from_root    = {"$" ~ root?}

select_term = _{from_current | from_root}

op = _{ge | gt | le | lt | eq | ne | re | in_op | nin_op | subsetof_op | anyof_op | noneof_op | size_op | empty_op}
    ge = @{">="}
    gt = @{">"}
    le = @{"<="}
    lt = @{"<"}
    eq = @{"=="}
    ne = @{"!="}
    re = @{"=~"}
    // Set-membership operators (word operators). The trailing boundary must match
    // `op_keyword` below so the operator and the path-segment guard agree.
    in_op = @{"in" ~ !(ASCII_ALPHANUMERIC | "_")}
    nin_op = @{"nin" ~ !(ASCII_ALPHANUMERIC | "_")}
    // Set-relation operators: both operands are arrays.
    subsetof_op = @{"subsetof" ~ !(ASCII_ALPHANUMERIC | "_")}
    anyof_op = @{"anyof" ~ !(ASCII_ALPHANUMERIC | "_")}
    noneof_op = @{"noneof" ~ !(ASCII_ALPHANUMERIC | "_")}
    // Size/emptiness operators: `left sizeof right` (|left| == right) and
    // `left empty <bool>`. `left` is an array or string.
    size_op = @{("sizeof" | "size") ~ !(ASCII_ALPHANUMERIC | "_")}
    empty_op = @{"empty" ~ !(ASCII_ALPHANUMERIC | "_")}

boolean = _{boolean_true | boolean_false}
    boolean_true = @{"true"}
    boolean_false = @{"false"}

null = @{"null"}

// JSON array/object literals usable as filter operands, e.g. `?@==[1]`, `?@=={"a":1}`
array_literal = {"[" ~ (json_value ~ ("," ~ json_value)*)? ~ "]"}
object_literal = {"{" ~ (object_member ~ ("," ~ object_member)*)? ~ "}"}
object_member = {string ~ ":" ~ json_value}
json_value = _{decimal | string | boolean | null | array_literal | object_literal}

// Filter-expression functions, e.g. `length(@)`, `match(@.s, "a.*")`. Args are terms.
function_name = @{ASCII_ALPHA ~ (ASCII_ALPHANUMERIC | "_")*}
function_call = {function_name ~ "(" ~ (term ~ ("," ~ term)*)? ~ ")"}

term = _{select_term | decimal | string | boolean | null | array_literal | object_literal | function_call}

// Arithmetic over filter operands. Operators must be space-separated, since the path
// `literal` charset already includes + - / % (so `@.a+1` is a field name, while
// `@.a + 1` is addition). Precedence: unary, then * / %, then + -.
// Division/modulo by zero (and any non-numeric operand) yields Nothing, so the
// comparison is false and the node is skipped (we yield Nothing rather than erroring).
add = @{"+"}
sub = @{"-"}
mul = @{"*"}
div = @{"/"}
rem = @{"%"}
add_op = _{add | sub}
mul_op = _{mul | div | rem}
neg = @{"-"}
pos = @{"+"}
unary_op = _{neg | pos}
arith_primary = _{"(" ~ arith_expr ~ ")" | term}
arith_factor = {unary_op? ~ arith_primary}
arith_term = {arith_factor ~ (mul_op ~ arith_factor)*}
arith_expr = {arith_term ~ (add_op ~ arith_term)*}

single_filter = {arith_expr ~ op ~ arith_expr | arith_expr}

filter_relation = _{and | or}
    and = {"&&"}
    or  = {"||"}

// Logical negation: `!` applies to a test or parenthesized filter, binding tighter than && / ||
negation = {"!" ~ inner_filter}

inner_filter = _{negation | single_filter | "(" ~ filter ~ ")"}

filter = {inner_filter ~ (filter_relation ~ inner_filter)*}

all = {"*"}

full_scan = {".."}

bracket = _{numbers_range | numbers_list | string_list | all | "?" ~ filter}

element = _{"." ~ literal | full_scan ~ (literal | all | "[" ~ bracket ~ "]") | "." ~ all | ("."? ~ "[" ~ bracket ~ "]")}

// The bare word operators must not be swallowed as a bare first path segment
// (e.g. `@ in [...]`). A field with one of these names is still reachable via
// `.name` / `["name"]`.
// NOTE: this is a deliberate, documented behavior change: a bare first segment with one
// of these names (e.g. `$in`, `@size`) no longer parses as a path to that field — use
// `$.size` / `$["size"]` instead.
op_keyword = @{("subsetof" | "noneof" | "anyof" | "sizeof" | "size" | "empty" | "nin" | "in") ~ !(ASCII_ALPHANUMERIC | "_")}

first_element = _{(!op_keyword ~ literal) | all}

root = {(element|first_element) ~ (element)*}

simple_root = {"." ~ literal}

query = _{SOI ~ "$" ~ root? ~ EOI}

simple_query = _{SOI ~ "$" ~ simple_root ~ EOI}

WHITESPACE = _{ " " }